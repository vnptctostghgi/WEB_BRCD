# Sao chep file nay thanh .env, sau do dien thong tin do don vi cung cap.
# Khong commit file .env len Git.
APP_NAME=BRCĐ Admin
APP_ENV=development
APP_DATABASE_BACKEND=sqlite
APP_DATABASE_PATH=data/app.db
SESSION_SECRET=hay-thay-bang-chuoi-bi-mat-dai-va-ngau-nhien
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=ChangeMe123!

# Doi thanh supabase sau khi da chay supabase_schema.sql va key hop le.
SUPABASE_REST_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

TELEGRAM_TOKEN=
BOT_TOKEN=
MY_TELEGRAM_ID=
BOT_USERNAME=

# true: chay thu khong can Oracle. false: ket noi Oracle that.
DB_MOCK_MODE=true

# Vi du: 10.10.10.10
DB_HOST=
# Cong mac dinh cua Oracle thuong la 1521.
DB_PORT=1521
# Service Name, KHONG phai SID. Vi du: ORCLPDB1
DB_SERVICE=
DB_USER=
DB_PASS=

# VPN SSL de vao mang co quan neu can. Khong commit mat khau that.
VPN_HOST=
VPN_PORT=4443
VPN_USERNAME=
VPN_PASSWORD=
VPN_TYPE=ssl

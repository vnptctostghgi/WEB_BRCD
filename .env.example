# Sao chép file này thành .env, sau đó điền thông tin do đơn vị cung cấp.
# Không commit file .env lên Git.
APP_NAME=Hệ thống quản trị đặc biệt
APP_ENV=development
APP_DATABASE_BACKEND=sqlite
APP_DATABASE_PATH=data/app.db
SESSION_SECRET=hay-thay-bang-chuoi-bi-mat-dai-va-ngau-nhien
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=ChangeMe123!

# Supabase là CSDL chính của web.
SUPABASE_REST_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# API trung gian nội bộ sẽ kết nối DB cơ quan và trả dữ liệu cho web.
INTERNAL_API_URL=http://10.92.17.88:8000/api/du-lieu-web
INTERNAL_API_MOCK_MODE=true
INTERNAL_API_TIMEOUT_SECONDS=20
INTERNAL_API_TOKEN=

# Telegram Bot chỉ gửi cảnh báo về MY_TELEGRAM_ID.
TELEGRAM_TOKEN=
BOT_TOKEN=
MY_TELEGRAM_ID=
BOT_USERNAME=

# Zalo Bot nhan webhook tai /api/zalo/webhook.
ZALO_BOT_TOKEN=
ZALO_WEBHOOK_URL=https://vnptcto.com/api/zalo/webhook
ZALO_WEBHOOK_SECRET=
ZALO_AUTO_REPLY_ENABLED=true

# OneBSS data mining. Khong commit mat khau that vao repo.
ONEBSS_LOGIN_URL=https://onebss.vnpt.vn/
ONEBSS_USERNAME=
ONEBSS_PASSWORD=
ONEBSS_DOWNLOAD_TIMEOUT_SECONDS=180
DATA_MINING_DOWNLOAD_DIR=data/data_mining_downloads
